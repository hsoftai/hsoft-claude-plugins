#!/bin/sh
# secrets-guard launcher: selects the matching prebuilt binary by OS/arch.
# Invoked by the plugin hooks as ${CLAUDE_PLUGIN_ROOT}/bin/secrets-guard.
set -eu

DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"

os="$(uname -s 2>/dev/null || echo unknown)"
arch="$(uname -m 2>/dev/null || echo unknown)"

# Windows (when this launcher is invoked from a POSIX shell such as Git Bash): the build is
# a .exe and is named differently, so dispatch to it directly. The companion
# secrets-guard.cmd handles the case where the hook is run by cmd.exe instead.
case "$os" in
  MINGW*|MSYS*|CYGWIN*|Windows_NT)
    exec "$DIR/secrets-guard-windows-amd64.exe" "$@" ;;
esac

case "$os" in
  Darwin) os_tag="darwin" ;;
  Linux)  os_tag="linux" ;;
  *)      os_tag="linux" ;;
esac

case "$arch" in
  arm64|aarch64) arch_tag="arm64" ;;
  x86_64|amd64)  arch_tag="amd64" ;;
  *)             arch_tag="amd64" ;;
esac

bin="$DIR/secrets-guard-${os_tag}-${arch_tag}"
if [ ! -x "$bin" ]; then
  echo "secrets-guard: no binary for ${os_tag}-${arch_tag} at $bin" >&2
  # Fail open: emit no decision so the user's session is never broken.
  exit 0
fi

exec "$bin" "$@"
